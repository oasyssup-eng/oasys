{
  "name": "oasys",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "npm run -w packages/database migrate:dev",
    "db:generate": "npm run -w packages/database generate",
    "db:seed": "npm run -w packages/database seed",
    "db:reset": "npm run -w packages/database reset"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.6.2"
}
